PORT=5000

# Supabase — Project Settings → API
# URL looks like: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Use the "service_role" key (NOT the anon key). Server-side only — never expose it.
SUPABASE_SERVICE_ROLE_KEY=

# Change this to a long random string in production
JWT_SECRET=sports_meet_secret_key_change_in_production
