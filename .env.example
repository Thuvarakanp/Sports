# Copy to server/.env for local development, and set the same variables in
# Vercel → Project → Settings → Environment Variables for production.

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the "service_role" key (NOT the anon key). Server-side only — never expose it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — change to a long random string
JWT_SECRET=change_me_to_a_long_random_string

# Local Express port (not used on Vercel)
PORT=5000
